{
  "name": "parchment",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:desktop": "bun tauri dev",
    "dev:ios": "bun tauri ios dev",
    "dev:android": "sh -c 'sleep 5 && adb reverse tcp:5000 tcp:5000' & bun tauri android dev",
    "build": "vue-tsc && vite build",
    "build:ios": "bun tauri ios build",
    "build:android": "bun tauri android build --aab",
    "build:android:apk": "bun tauri android build --apk --verbose",
    "tauri:clean": "cd src-tauri && cargo clean",
    "preview": "vite preview",
    "docker:dev": "docker-compose up --build",
    "docker:prod": "docker build -t parchment-frontend . && docker run -d -p 8080:80 parchment-frontend"
  },
  "trustedDependencies": [
    "@morev/vue-transitions"
  ],
  "dependencies": {
    "@internationalized/date": "^3.5.4",
    "@mdi/js": "^7.4.47",
    "@morev/vue-transitions": "^3.0.2",
    "@simplewebauthn/browser": "^10.0.0",
    "@tanstack/vue-table": "^8.17.0",
    "@tauri-apps/plugin-os": "~2",
    "@tauri-apps/plugin-store": "~2",
    "@vee-validate/zod": "^4.12.8",
    "@vueuse/core": "^12.3.0",
    "@vueuse/gesture": "^2.0.0",
    "@vueuse/motion": "^2.2.6",
    "axios": "^1.6.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "drizzle-orm": "^0.43.1",
    "fuzzysort": "^2.0.4",
    "lucide-vue-next": "0.475.0",
    "mapbox-gl": "^3.10.0",
    "mapillary-js": "^4.1.2",
    "maplibre-gl": "^4.2.0",
    "mitt": "^3.0.1",
    "mousetrap": "^1.6.5",
    "pinia": "^2.1.7",
    "pinia-orm": "^1.10.2",
    "pluscodes": "^2.6.0",
    "radix-vue": "^1.9.12",
    "simple-icons": "^14.12.2",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
