# Database credentials
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password

# Server configuration
SERVER_ORIGIN=http://your_server_ip:5000
CLIENT_ORIGIN=http://your_server_ip:5173

# Federation server identity (Ed25519 seed, base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
# In development this can be omitted; a random ephemeral key will be used.
# Required in production — persist this so your server identity is stable.
SERVER_IDENTITY_PRIVATE_KEY=

# Integration credential encryption key (AES-256 master key, base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
# Encrypts third-party API keys / bearer tokens stored in the integrations table.
# In development this can be omitted; a random ephemeral key is generated and
# any saved integrations become unreadable after restart.
# In production, provide via whatever secrets mechanism your deploy uses —
# plain env var injection is fine. If you happen to run on AWS/GCP/Vault
# you can unseal from those services before startup and inject the 32 bytes
# as this env var, but no external key service is required.
PARCHMENT_INTEGRATION_ENCRYPTION_KEY=

# Email configuration
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
APP_TESTER_EMAIL=your_test_email@gmail.com

# Docs site
NEXT_PUBLIC_CLIENT_ORIGIN=http://your_server_ip:5173
