default_platform(:ios)

platform :ios do
  desc "Build for App Store (CI)"
  lane :release do
    # Setup keychain for CI
    if ENV['CI']
      create_keychain(
        name: "fastlane_tmp_keychain",
        password: "temp",
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
      
      # Import certificate
      import_certificate(
        certificate_path: ENV["CERTIFICATE_PATH"],
        certificate_password: ENV["CERTIFICATE_PASSWORD"],
        keychain_name: "fastlane_tmp_keychain",
        keychain_password: "temp"
      )
      
      # Install profile
      install_provisioning_profile(path: ENV["PROVISIONING_PROFILE_PATH"])
    end
    
    # Build
    build_ios_app(
      project: "app.xcodeproj",
      scheme: "app_iOS",
      configuration: "release",
      export_method: "app-store",
      output_directory: "./build/arm64",
      output_name: "Parchment.ipa",
      clean: false,
      destination: "generic/platform=iOS",
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        method: "app-store",
        teamID: "QPNGAD5BD2",
        provisioningProfiles: {
          "app.parchment" => ENV["PROVISIONING_PROFILE_SPECIFIER"] || "iOS Team Provisioning Profile: app.parchment"
        }
      }
    )
  end
end
