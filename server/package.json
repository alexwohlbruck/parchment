{
  "name": "parchment",
  "version": "0.0.17",
  "scripts": {
    "dev": "bun src/index.ts --watch",
    "build": "bun build ./src/index.ts ./src/migrate.ts ./src/seed/seed.ts --outdir ./dist --target bun",
    "start": "bun dist/index.js",
    "start:server2": "PORT=5001 SERVER_ORIGIN=http://localhost:5001 CLIENT_ORIGIN=http://localhost:5173 bun src/index.ts",
    "test": "bun test",
    "generate": "drizzle-kit generate",
    "migrate:dev": "bun run generate && bun src/migrate.ts",
    "migrate:prod": "bun dist/migrate.js",
    "seed:dev": "bun src/seed/seed.ts",
    "seed:prod": "bun dist/seed/seed.js",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/eden": "^1.3.2",
    "@elysiajs/swagger": "^1.3.1",
    "@lucia-auth/adapter-drizzle": "^1.0.7",
    "@neondatabase/serverless": "^1.0.1",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "@openstreetmap/id-tagging-schema": "^6.12.0",
    "@simplewebauthn/browser": "^10.0.0",
    "@simplewebauthn/server": "^10.0.0",
    "@simplewebauthn/types": "^10.0.0",
    "@turf/turf": "^7.2.0",
    "@types/lodash": "^4.17.17",
    "@types/nodemailer": "^6.4.15",
    "axios": "^1.8.4",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.43.1",
    "elysia": "^1.4.22",
    "elysia-i18next": "^4.0.3",
    "fuzzball": "^2.2.2",
    "geojson": "^0.5.0",
    "i18next": "^25.3.6",
    "lodash": "^4.17.21",
    "lucia": "^3.2.2",
    "md5": "^2.3.0",
    "nodemailer": "^6.9.13",
    "oslo": "^1.2.1",
    "pg": "^8.14.1",
    "pino": "^9.7.0",
    "pluscodes": "^2.6.0",
    "postgres": "^3.4.5",
    "qs": "^6.14.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/qs": "^6.14.0",
    "bun-types": "latest"
  },
  "module": "src/index.js"
}