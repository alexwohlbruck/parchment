{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "parchment",
  "version": "0.0.7",
  "identifier": "app.parchment",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "VITE_SERVER_ORIGIN='https://api.parchment.app' bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Parchment",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "app.parchment"
    },
    "android": {
      "versionCode": 4
    }
  }
}