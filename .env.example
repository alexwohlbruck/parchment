# Database credentials
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password

# Server configuration
SERVER_ORIGIN=http://your_server_ip:5000
CLIENT_ORIGIN=http://your_server_ip:5173

# The next two server keys must be INDEPENDENT random values —
# do NOT use the same bytes for both. One is an Ed25519 signing seed
# whose public half is exposed at /.well-known/parchment-server; the other
# is an AES-256 symmetric key. Sharing bytes across signing + encryption
# primitives is a cryptographic anti-pattern. Generate two separate keys:
#
#     openssl rand -base64 32   # → SERVER_IDENTITY_PRIVATE_KEY
#     openssl rand -base64 32   # → PARCHMENT_INTEGRATION_ENCRYPTION_KEY

# Federation server identity (Ed25519 seed, base64-encoded 32 bytes).
# REQUIRED — the server refuses to start without this, in every environment.
# Persist this so your server identity is stable across restarts; rotation
# breaks TOFU pinning on every peer until they manually re-pin.
SERVER_IDENTITY_PRIVATE_KEY=

# Integration credential encryption key (AES-256 master key, base64-encoded 32 bytes).
# REQUIRED — the server refuses to start without this, in every environment.
# Encrypts third-party API keys / bearer tokens stored in the integrations
# table. Provide via whatever secrets mechanism your deploy uses; plain env
# var injection is fine. If you happen to run on AWS/GCP/Vault you can
# unseal from those services before startup and inject the 32 bytes as
# this env var, but no external key service is required.
PARCHMENT_INTEGRATION_ENCRYPTION_KEY=

# Email configuration
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
APP_TESTER_EMAIL=your_test_email@gmail.com

# Docs site
NEXT_PUBLIC_CLIENT_ORIGIN=http://your_server_ip:5173
