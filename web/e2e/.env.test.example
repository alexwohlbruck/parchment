# Copy to repo root as .env.test (gitignored – do not commit).
#   cp web/e2e/env.test.example .env.test
# Used by: docker compose -f docker-compose.test.yml --env-file .env.test
# Playwright loads it too. Fill in base values and any E2E_* keys you need.
#
# ─── Base (required) ──────────────────────────────────────────────────────────
POSTGRES_DB=parchment_test
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password

SERVER_ORIGIN=http://localhost:5001
CLIENT_ORIGIN=http://localhost:5174

# Test user – receives OTP 0000-0000 when signing in
APP_TESTER_EMAIL=test@parchment.local

GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

#
# ─── E2E integrations (optional) ───────────────────────────────────────────────
# E2E_GOOGLE_MAPS_API_KEY=
# E2E_GEOAPIFY_API_KEY=
# E2E_OPENWEATHERMAP_API_KEY=
# E2E_GRAPHHOPPER_API_KEY=
# E2E_GRAPHHOPPER_HOST=
# E2E_PELIAS_HOST=
# E2E_PELIAS_API_KEY=
# E2E_OVERPASS_HOST=
# E2E_NOMINATIM_HOST=
# E2E_VALHALLA_HOST=
