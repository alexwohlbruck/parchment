#!/bin/bash
# Wrapper so xcodebuild gets -destination 'generic/platform=iOS' (Tauri doesn't pass it).
# With automatic signing, just add destination. CI overrides with CODE_SIGN_STYLE=Manual + profile.

# Debug output (will appear in CI logs)
if [ -n "$CODE_SIGN_STYLE" ]; then
  echo "[xcodebuild wrapper] CODE_SIGN_STYLE=$CODE_SIGN_STYLE"
  echo "[xcodebuild wrapper] CODE_SIGN_IDENTITY=$CODE_SIGN_IDENTITY"
  echo "[xcodebuild wrapper] PROVISIONING_PROFILE_SPECIFIER=$PROVISIONING_PROFILE_SPECIFIER"
  echo "[xcodebuild wrapper] DEVELOPMENT_TEAM=$DEVELOPMENT_TEAM"
fi

XCB="/Applications/Xcode.app/Contents/Developer/usr/bin/xcodebuild"
EXTRA=()
[ -n "$CODE_SIGN_STYLE" ] && EXTRA+=(CODE_SIGN_STYLE="$CODE_SIGN_STYLE")
[ -n "$CODE_SIGN_IDENTITY" ] && EXTRA+=(CODE_SIGN_IDENTITY="$CODE_SIGN_IDENTITY")
[ -n "$PROVISIONING_PROFILE_SPECIFIER" ] && EXTRA+=(PROVISIONING_PROFILE_SPECIFIER="$PROVISIONING_PROFILE_SPECIFIER")
[ -n "$DEVELOPMENT_TEAM" ] && EXTRA+=(DEVELOPMENT_TEAM="$DEVELOPMENT_TEAM")

echo "[xcodebuild wrapper] Executing: $XCB ${EXTRA[@]} $@ -destination 'generic/platform=iOS'"
exec "$XCB" "${EXTRA[@]}" "$@" -destination 'generic/platform=iOS'
