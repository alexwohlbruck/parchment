{
  "name": "parchment",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun --watch --inspect src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./build --target bun",
    "start": "NODE_ENV=production bun src/index.ts",
    "test": "bun test",
    "generate": "drizzle-kit generate:pg",
    "seed": "bun src/seed.ts",
    "migrate": "bun generate; bun src/migrate.ts",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.0.2",
    "@elysiajs/eden": "^1.0.12",
    "@elysiajs/swagger": "^1.0.3",
    "@lucia-auth/adapter-drizzle": "^1.0.7",
    "@neondatabase/serverless": "^0.9.0",
    "@simplewebauthn/browser": "^10.0.0",
    "@simplewebauthn/server": "^10.0.0",
    "@simplewebauthn/types": "^10.0.0",
    "@types/nodemailer": "^6.4.15",
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.3",
    "elysia": "latest",
    "lucia": "^3.1.1",
    "nodemailer": "^6.9.13",
    "oslo": "^1.1.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.20.14",
    "postgres": "^3.4.4"
  },
  "module": "src/index.js"
}