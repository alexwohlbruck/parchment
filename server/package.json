  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/eden": "^1.2.0",
    "@elysiajs/swagger": "^1.2.2",
    "@lucia-auth/adapter-drizzle": "^1.0.7",
    "@simplewebauthn/browser": "^10.0.0",
    "@simplewebauthn/server": "^10.0.0",
    "@simplewebauthn/types": "^10.0.0",
    "@turf/turf": "^7.2.0",
    "@types/nodemailer": "^6.4.15",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.43.1",
    "elysia": "^1.2.25",
    "geojson": "^0.5.0",
    "lucia": "^3.2.2",
    "md5": "^2.3.0",
    "nodemailer": "^6.9.13",
    "oslo": "^1.2.1",
    "pg": "^8.14.1",
    "pluscodes": "^2.6.0",
